APP_NAME="Talksasa Cloud"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Background scheduler — set true on production servers with OS cron/systemd timer
# SCHEDULER_ENABLED=true
# SCHEDULER_LOG_OUTPUT=false
# SCHEDULER_ON_ONE_SERVER=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=talksasa_cloud
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie

CONTAINER_RUNTIME_REGISTRY=talksasa
CONTAINER_RUNTIME_BUILD_ON_DEPLOY=true
LARAVEL_INIT_COMPOSER_CONSTRAINT=^12.0

CONTAINER_TERMINAL_WS_ENABLED=true
CONTAINER_TERMINAL_WS_HOST=0.0.0.0
CONTAINER_TERMINAL_WS_PORT=8088
CONTAINER_TERMINAL_WS_PUBLIC_URL=
CONTAINER_TERMINAL_WS_PATH=/container-terminal

# Reseller branding → Provision SSL (run scripts/reseller-ssl/install-host.sh once on the server)
RESELLER_SSL_CERTBOT_SUDO=true
RESELLER_SSL_USE_PROVISION_SCRIPT=true
# RESELLER_SSL_PROVISION_SCRIPT=/var/www/talksasa-cloud/scripts/reseller-ssl/provision.sh
# RESELLER_SSL_CERTBOT_PATH=/usr/bin/certbot

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@talksasa.cloud
MAIL_FROM_NAME="${APP_NAME}"

DIRECTADMIN_API_URL=
DIRECTADMIN_API_USERNAME=
DIRECTADMIN_API_PASSWORD=

# PayPal partner app (optional — can also be set in Admin → Settings → PayPal)
# PAYPAL_PARTNER_CLIENT_ID=
# PAYPAL_PARTNER_CLIENT_SECRET=
# PAYPAL_PARTNER_MERCHANT_ID=
# PAYPAL_PARTNER_BN_CODE=
